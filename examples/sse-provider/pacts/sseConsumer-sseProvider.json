{
  "consumer": {
    "name": "sseConsumer"
  },
  "interactions": [
    {
      "description": "request for events",
      "interactionMarkup": {
        "markup": "# SSE Events\n\n|type|data|\n|---|---|\n||simple text|\n|count|100|\n|time|2000-01-01|\n|user|user data payload|\n||100|\n|user|5d03dc45-96f6-4c0c-b1ad-aa67242058cc|\n",
        "markupType": "COMMON_MARK"
      },
      "pending": false,
      "providerStates": [
        {
          "name": "events are available"
        }
      ],
      "request": {
        "headers": {
          "Accept": [
            "text/event-stream"
          ]
        },
        "method": "GET",
        "path": "/events"
      },
      "response": {
        "body": {
          "content": "data:simple text\n\nevent:count\ndata:100\n\nevent:time\ndata:2000-01-01\n\nevent:user\ndata:user data payload\n\ndata:100\n\nevent:user\ndata:5d03dc45-96f6-4c0c-b1ad-aa67242058cc\n\n",
          "contentType": "text/event-stream",
          "contentTypeHint": "DEFAULT",
          "encoded": false
        },
        "generators": {
          "body": {
            "data.time.*": {
              "format": "yyyy-MM-dd",
              "type": "DateTime"
            }
          }
        },
        "headers": {
          "Cache-Control": [
            "no-cache"
          ],
          "X-Accel-Buffering": [
            "no"
          ],
          "content-type": [
            "text/event-stream"
          ]
        },
        "matchingRules": {
          "body": {
            "data.*": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "data.count.*": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "number"
                }
              ]
            },
            "data.time.*": {
              "combine": "AND",
              "matchers": [
                {
                  "format": "yyyy-MM-dd",
                  "match": "datetime"
                }
              ]
            },
            "data.user.*": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "id.*": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "number"
                }
              ]
            },
            "id.user.*": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^[0-9a-f]{8}(-[0-9a-f]{4}){3}-[0-9a-f]{12}$"
                }
              ]
            }
          }
        },
        "status": 200
      },
      "transport": "http",
      "type": "Synchronous/HTTP"
    }
  ],
  "metadata": {
    "pactRust": {
      "ffi": "0.5.3",
      "mockserver": "2.2.1",
      "models": "1.3.9"
    },
    "pactSpecification": {
      "version": "4.0"
    },
    "plugins": [
      {
        "configuration": {},
        "name": "sse",
        "version": "0.1.0"
      }
    ]
  },
  "provider": {
    "name": "sseProvider"
  }
}